# See ../../ops/env.sync.example (repo root) for cross-service alignment.
# Required
DATABASE_URL="postgresql://nexu:nexu_pass@localhost:5432/nexustore"

# Recommended
PORT=4000
NODE_ENV=development
HOST=0.0.0.0
JWT_SECRET=dev_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# Optional integrations
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672

# Optional Google OAuth (leave empty to disable Google auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Optional mail/OTP
MAIL_USER=
MAIL_PASS=

# Optional payment config
REDSYS_URL=https://sis-t.redsys.es:25443/sis/realizarPago
REDSYS_MERCHANT_CODE=999008881
REDSYS_TERMINAL=1
REDSYS_SECRET_KEY=
