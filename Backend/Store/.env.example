# See ../../ops/env.sync.example (repo root) for cross-service alignment.
# Required
DATABASE_URL="postgresql://nexu:nexu_pass@localhost:5432/nexustore"

# Recommended
PORT=4000
NODE_ENV=development
HOST=0.0.0.0
JWT_SECRET=dev_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# Optional integrations
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672

# Optional Google OAuth (leave empty to disable Google auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# Optional mail/OTP
# Defaults are Gmail-compatible. Override MAIL_HOST/MAIL_PORT/MAIL_SECURE for other providers.
MAIL_USER=
MAIL_PASS=
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_FROM=
MAIL_FROM_NAME=NEXUS

# Optional payment config
REDSYS_ENV=test
REDSYS_URL=https://sis-t.redsys.es:25443/sis/realizarPago
REDSYS_MERCHANT_CODE=999008881
REDSYS_TERMINAL=1
REDSYS_SECRET_KEY=
REDSYS_NOTIFY_URL=http://localhost:4000/payments/redsys/notify
REDSYS_OK_URL=http://localhost:4000/payments/redsys/ok
REDSYS_KO_URL=http://localhost:4000/payments/redsys/ko


# Optional: override branding storage path to a directory outside the repo
# so it persists across git clean / deploy updates.
# Defaults to <repo>/Backend/Store/storage/branding
# BRANDING_STORAGE_DIR=/opt/nexus-storage/branding
