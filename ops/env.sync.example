# NexuStore environment synchronization template (Phase 1)
# Copy and split these values into each service-specific .env file.

# Shared core
NODE_ENV=development
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000

# Backend/Store
DATABASE_URL=postgresql://nexu:nexu_pass@localhost:5432/nexustore
JWT_SECRET=dev_secret
JWT_EXPIRES_IN=7d
HOST=0.0.0.0
PORT=4000
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://localhost:5672

# Frontend/Store
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Frontend/admin
NEXT_PUBLIC_API_URL=http://localhost:4000
# This URL points to the public storefront used by banner previews/links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
