generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SkuStatus {
  ACTIVE
  INACTIVE
}

enum MediaType {
  IMAGE
  MANUAL
  DATASHEET
}

enum DataType {
  TEXT
  NUMBER
  BOOLEAN
  ENUM
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum SupplierSnapshotType {
  CATALOG
  STOCK
  PRICES
  IMAGES
}

enum SupplierSnapshotStatus {
  OK
  FAILED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  FAILED
}

enum FulfillmentType {
  INTERNAL
  SUPPLIER
}

enum PaymentProvider {
  REDSYS
  STRIPE
  PAYPAL
}

enum PaymentStatus {
  INITIATED
  AUTHORIZED
  CAPTURED
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  EXCEPTION
}

enum RmaStatus {
  REQUESTED
  APPROVED
  REJECTED
  RECEIVED
  REFUNDED
  CLOSED
}

enum ResolutionType {
  REFUND
  REPLACE
}

enum RefundStatus {
  INITIATED
  SUCCEEDED
  FAILED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum ConsentType {
  MARKETING_EMAIL
  TERMS_ACCEPTED
  PRIVACY_ACCEPTED
}

enum ActorType {
  CUSTOMER
  STAFF
  SYSTEM
}

enum JobType {
  IMPORT_CATALOG
  IMPORT_STOCK
  IMPORT_PRICES
  GENERATE_INVOICE
  SEND_EMAIL
  SYNC_TRACKING
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  RETRYING
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum PricingRuleScope {
  GLOBAL
  CATEGORY
  BRAND
  SKU
}

enum RoundingMode {
  NONE
  X_99
  X_95
}

enum CouponType {
  PERCENT
  FIXED
}

enum StaffRole {
  ADMIN
  WAREHOUSE
}

model Staff {
  id            String    @id @default(uuid())
  email         String    @unique @db.Citext
  password_hash String
  role          StaffRole
  warehouse_id  String?
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  warehouse Warehouse? @relation(fields: [warehouse_id], references: [id])

  @@index([role])
}

model Brand {
  id            String        @id @default(uuid())
  name          String        @unique
  slug          String        @unique
  logo_url      String?
  is_active     Boolean       @default(true)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  products      Product[]
  pricing_rules PricingRule[]
}

model Category {
  id         String   @id @default(uuid())
  parent_id  String?  @map("parent_id")
  name       String
  slug       String   @unique
  sort_order Int
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  parent   Category?  @relation("CategoryToCategory", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryToCategory")

  products      ProductCategory[]
  products_main Product[]         @relation("ProductMainCategory")

  pricing_rules PricingRule[]

  @@index([parent_id, sort_order])
}

model Product {
  id                String        @id @default(uuid())
  title             String
  slug              String        @unique
  brand_id          String
  description_html  String?
  short_description String?
  status            ProductStatus @default(DRAFT)
  main_category_id  String?       @map("main_category_id")

  rating_avg   Decimal? @db.Decimal(2, 1)
  rating_count Int      @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  brand         Brand             @relation(fields: [brand_id], references: [id])
  main_category Category?         @relation("ProductMainCategory", fields: [main_category_id], references: [id])
  categories    ProductCategory[]
  skus          Sku[]
  media         ProductMedia[]
  reviews       ProductReview[]

  @@index([slug])
}

model ProductReview {
  id          String   @id @default(uuid())
  product_id  String
  customer_id String?
  rating      Int
  title       String?
  comment     String?
  is_approved Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  product  Product   @relation(fields: [product_id], references: [id])
  customer Customer? @relation(fields: [customer_id], references: [id])

  @@unique([product_id, customer_id])
  @@index([product_id])
}

model ProductCategory {
  product_id  String
  category_id String
  is_primary  Boolean  @default(false)
  sort_order  Int
  product     Product  @relation(fields: [product_id], references: [id])
  category    Category @relation(fields: [category_id], references: [id])

  @@id([product_id, category_id])
}

model Sku {
  id            String    @id @default(uuid())
  product_id    String
  sku_code      String    @unique
  gtin          String?
  mpn           String?
  name          String?
  status        SkuStatus @default(ACTIVE)
  weight_grams  Int?
  dimensions_mm Json?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  product           Product           @relation(fields: [product_id], references: [id])
  media             ProductMedia[]
  attributes        SkuAttribute[]
  supplier_products SupplierProduct[]
  prices            SkuPrice[]
  inventory         InventoryLevel[]
  cart_items        CartItem[]
  order_items       OrderItem[]

  pricing_rules PricingRule[]

  @@index([sku_code])
}

model ProductMedia {
  id         String    @id @default(uuid())
  product_id String
  sku_id     String?   @map("sku_id")
  type       MediaType
  url        String
  alt_text   String?
  sort_order Int
  created_at DateTime  @default(now())
  product    Product   @relation(fields: [product_id], references: [id])
  sku        Sku?      @relation(fields: [sku_id], references: [id])
}

model Attribute {
  id             String           @id @default(uuid())
  code           String           @unique
  name           String
  data_type      DataType
  unit           String?
  is_filterable  Boolean          @default(false)
  created_at     DateTime         @default(now())
  values         AttributeValue[]
  sku_attributes SkuAttribute[]
}

model AttributeValue {
  id             String         @id @default(uuid())
  attribute_id   String
  value_text     String
  sort_order     Int
  attribute      Attribute      @relation(fields: [attribute_id], references: [id])
  sku_attributes SkuAttribute[]

  @@unique([attribute_id, value_text])
}

model SkuAttribute {
  sku_id             String
  attribute_id       String
  value_text         String?
  value_number       Decimal?
  value_bool         Boolean?
  attribute_value_id String?         @map("attribute_value_id")
  sku                Sku             @relation(fields: [sku_id], references: [id])
  attribute          Attribute       @relation(fields: [attribute_id], references: [id])
  attribute_value    AttributeValue? @relation(fields: [attribute_value_id], references: [id])

  @@id([sku_id, attribute_id])
  @@index([attribute_id, value_number])
  @@index([attribute_id, attribute_value_id])
  @@index([attribute_id, value_text])
}

model Supplier {
  id         String         @id @default(uuid())
  name       String         @unique
  code       String         @unique
  status     SupplierStatus @default(ACTIVE)
  config     Json
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt

  products    SupplierProduct[]
  snapshots   SupplierRawSnapshot[]
  order_items OrderItem[]
}

model SupplierProduct {
  id                    String         @id @default(uuid())
  supplier_id           String
  supplier_sku          String
  sku_id                String?        @map("sku_id")
  supplier_payload_hash String
  last_seen_at          DateTime
  is_active             Boolean        @default(true)
  supplier              Supplier       @relation(fields: [supplier_id], references: [id])
  sku                   Sku?           @relation(fields: [sku_id], references: [id])
  stock                 SupplierStock?
  price                 SupplierPrice?
  order_items           OrderItem[]

  @@unique([supplier_id, supplier_sku])
}

model SupplierStock {
  supplier_product_id String          @id @map("supplier_product_id")
  qty_available       Int
  qty_inbound         Int?
  availability_code   String?
  updated_at          DateTime        @default(now())
  supplier_product    SupplierProduct @relation(fields: [supplier_product_id], references: [id])
}

model SupplierPrice {
  supplier_product_id String          @id @map("supplier_product_id")
  cost_price          Decimal         @db.Decimal(12, 2)
  currency            String          @default("EUR")
  updated_at          DateTime        @default(now())
  supplier_product    SupplierProduct @relation(fields: [supplier_product_id], references: [id])
}

model SupplierRawSnapshot {
  id          String                 @id @default(uuid())
  supplier_id String
  type        SupplierSnapshotType
  fetched_at  DateTime
  source_ref  String?
  payload     String
  checksum    String
  status      SupplierSnapshotStatus
  error       String?
  supplier    Supplier               @relation(fields: [supplier_id], references: [id])
}

model PricingRule {
  id                String           @id @default(uuid())
  scope             PricingRuleScope
  category_id       String?          @map("category_id")
  brand_id          String?          @map("brand_id")
  sku_id            String?          @map("sku_id")
  margin_pct        Decimal          @db.Decimal(5, 2)
  min_margin_amount Decimal?         @db.Decimal(12, 2)
  rounding_mode     RoundingMode
  is_active         Boolean          @default(true)
  priority          Int
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  category          Category?        @relation(fields: [category_id], references: [id])
  brand             Brand?           @relation(fields: [brand_id], references: [id])
  sku               Sku?             @relation(fields: [sku_id], references: [id])
}

model SkuPrice {
  sku_id           String   @id @map("sku_id")
  sale_price       Decimal  @db.Decimal(12, 2)
  compare_at_price Decimal? @db.Decimal(12, 2)
  currency         String   @default("EUR")
  price_source     String
  updated_at       DateTime @default(now())
  sku              Sku      @relation(fields: [sku_id], references: [id])
}

model Warehouse {
  id         String           @id @default(uuid())
  name       String
  code       String           @unique
  created_at DateTime         @default(now())
  inventory  InventoryLevel[]
  Staff      Staff[]
}

model InventoryLevel {
  warehouse_id String
  sku_id       String
  qty_on_hand  Int       @default(0)
  qty_reserved Int       @default(0)
  updated_at   DateTime  @default(now())
  warehouse    Warehouse @relation(fields: [warehouse_id], references: [id])
  sku          Sku       @relation(fields: [sku_id], references: [id])

  @@id([warehouse_id, sku_id])
}

model Customer {
  id            String  @id @default(uuid())
  email         String  @unique @db.Citext
  password_hash String?
  first_name    String
  last_name     String
  phone         String?
  is_active     Boolean @default(false)

  profile_image String?
  role          String  @default("CUSTOMER")

  otp_code       String?
  otp_expires_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  addresses CustomerAddress[]
  consents  CustomerConsent[]
  carts     Cart[]
  orders    Order[]
  rmas      Rma[]

  reviews ProductReview[]
}

model CustomerAddress {
  id            String      @id @default(uuid())
  customer_id   String
  type          AddressType
  full_name     String
  company       String?
  vat_id        String?
  address_line1 String
  address_line2 String?
  city          String
  postal_code   String
  region        String
  country       String
  phone         String?
  is_default    Boolean     @default(false)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  customer      Customer    @relation(fields: [customer_id], references: [id])
}

model CustomerConsent {
  id          String      @id @default(uuid())
  customer_id String
  type        ConsentType
  version     String
  accepted_at DateTime
  source      String
  ip_address  String?
  customer    Customer    @relation(fields: [customer_id], references: [id])
}

model Cart {
  id          String     @id @default(uuid())
  customer_id String?    @map("customer_id")
  session_id  String?
  status      CartStatus @default(ACTIVE)
  currency    String     @default("EUR")
  created_at  DateTime   @default(now())
  updated_at  DateTime   @updatedAt
  customer    Customer?  @relation(fields: [customer_id], references: [id])
  items       CartItem[]
}

model CartItem {
  id                  String   @id @default(uuid())
  cart_id             String
  sku_id              String
  qty                 Int
  unit_price_snapshot Decimal? @db.Decimal(12, 2)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  cart                Cart     @relation(fields: [cart_id], references: [id])
  sku                 Sku      @relation(fields: [sku_id], references: [id])

  @@unique([cart_id, sku_id])
}

model Order {
  id                    String          @id @default(uuid())
  order_number          String          @unique
  customer_id           String?         @map("customer_id")
  email                 String          @db.Citext
  status                OrderStatus     @default(PENDING_PAYMENT)
  currency              String          @default("EUR")
  subtotal_amount       Decimal         @db.Decimal(12, 2)
  shipping_amount       Decimal         @db.Decimal(12, 2)
  discount_amount       Decimal         @db.Decimal(12, 2)
  tax_amount            Decimal         @db.Decimal(12, 2)
  total_amount          Decimal         @db.Decimal(12, 2)
  billing_address_json  Json
  shipping_address_json Json
  created_at            DateTime        @default(now())
  updated_at            DateTime        @updatedAt
  paid_at               DateTime?
  customer              Customer?       @relation(fields: [customer_id], references: [id])
  items                 OrderItem[]
  payments              Payment[]
  invoice               Invoice?
  shipments             Shipment[]
  discounts             OrderDiscount[]
  rmas                  Rma[]

  @@index([customer_id, created_at(sort: Desc)])
}

model OrderItem {
  id                  String           @id @default(uuid())
  order_id            String
  sku_id              String
  title_snapshot      String
  unit_price          Decimal          @db.Decimal(12, 2)
  qty                 Int
  line_subtotal       Decimal          @db.Decimal(12, 2)
  tax_amount          Decimal          @db.Decimal(12, 2)
  line_total          Decimal          @db.Decimal(12, 2)
  fulfillment_type    FulfillmentType
  supplier_id         String?          @map("supplier_id")
  supplier_product_id String?          @map("supplier_product_id")
  created_at          DateTime         @default(now())
  order               Order            @relation(fields: [order_id], references: [id])
  sku                 Sku              @relation(fields: [sku_id], references: [id])
  supplier            Supplier?        @relation(fields: [supplier_id], references: [id])
  supplier_product    SupplierProduct? @relation(fields: [supplier_product_id], references: [id])
  shipment_items      ShipmentItem[]
  rma_items           RmaItem[]

  @@index([order_id])
}

model Payment {
  id                  String          @id @default(uuid())
  order_id            String
  provider            PaymentProvider
  status              PaymentStatus
  amount              Decimal         @db.Decimal(12, 2)
  currency            String
  provider_payment_id String?
  raw_response        Json?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  order               Order           @relation(fields: [order_id], references: [id])
  refunds             Refund[]
}

model Invoice {
  id              String   @id @default(uuid())
  order_id        String   @unique
  invoice_number  String   @unique
  issued_at       DateTime
  pdf_url         String
  billing_company String?
  billing_vat_id  String?
  totals_json     Json
  created_at      DateTime @default(now())
  order           Order    @relation(fields: [order_id], references: [id])
}

model Shipment {
  id              String          @id @default(uuid())
  order_id        String
  carrier         String
  service_level   String?
  tracking_number String?
  tracking_url    String?
  status          ShipmentStatus  @default(PENDING)
  shipped_at      DateTime?
  delivered_at    DateTime?
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt
  order           Order           @relation(fields: [order_id], references: [id])
  items           ShipmentItem[]
  tracking_events TrackingEvent[]
}

model ShipmentItem {
  shipment_id   String
  order_item_id String
  shipment      Shipment  @relation(fields: [shipment_id], references: [id])
  order_item    OrderItem @relation(fields: [order_item_id], references: [id])

  @@id([shipment_id, order_item_id])
}

model TrackingEvent {
  id          String   @id @default(uuid())
  shipment_id String
  event_time  DateTime
  status      String
  location    String?
  details     String?
  shipment    Shipment @relation(fields: [shipment_id], references: [id])
}

model Rma {
  id          String    @id @default(uuid())
  rma_number  String    @unique
  order_id    String
  customer_id String?   @map("customer_id")
  status      RmaStatus @default(REQUESTED)
  reason_code String
  notes       String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  order       Order     @relation(fields: [order_id], references: [id])
  customer    Customer? @relation(fields: [customer_id], references: [id])
  items       RmaItem[]
  refunds     Refund[]
}

model RmaItem {
  id            String         @id @default(uuid())
  rma_id        String
  order_item_id String
  qty           Int
  resolution    ResolutionType
  rma           Rma            @relation(fields: [rma_id], references: [id])
  order_item    OrderItem      @relation(fields: [order_item_id], references: [id])
}

model Refund {
  id                 String       @id @default(uuid())
  payment_id         String
  rma_id             String?      @map("rma_id")
  amount             Decimal      @db.Decimal(12, 2)
  status             RefundStatus @default(INITIATED)
  provider_refund_id String?
  raw_response       Json?
  created_at         DateTime     @default(now())
  updated_at         DateTime     @updatedAt
  payment            Payment      @relation(fields: [payment_id], references: [id])
  rma                Rma?         @relation(fields: [rma_id], references: [id])
}

model Coupon {
  id               String          @id @default(uuid())
  code             String          @unique
  type             CouponType
  value            Decimal         @db.Decimal(12, 2)
  min_order_amount Decimal?        @db.Decimal(12, 2)
  starts_at        DateTime?
  ends_at          DateTime?
  usage_limit      Int?
  is_active        Boolean         @default(true)
  order_discounts  OrderDiscount[]
}

model OrderDiscount {
  order_id  String
  coupon_id String
  amount    Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [order_id], references: [id])
  coupon    Coupon  @relation(fields: [coupon_id], references: [id])

  @@id([order_id, coupon_id])
}

model Job {
  id         String    @id @default(uuid())
  type       JobType
  status     JobStatus @default(QUEUED)
  payload    Json
  attempts   Int       @default(0)
  run_at     DateTime
  last_error String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
}

model WebhookEvent {
  id           String        @id @default(uuid())
  source       String
  event_type   String
  received_at  DateTime      @default(now())
  payload      Json
  processed_at DateTime?
  status       WebhookStatus @default(RECEIVED)
  error        String?
}

model AuditLog {
  id          String    @id @default(uuid())
  actor_type  ActorType
  actor_id    String?
  action      String
  entity_type String
  entity_id   String?
  metadata    Json?
  created_at  DateTime  @default(now())
}
